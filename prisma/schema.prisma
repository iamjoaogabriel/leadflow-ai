// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled (Supavisor / pgBouncer) — used by the app at runtime.
  // Add `?pgbouncer=true&connection_limit=10` to the URL.
  url       = env("DATABASE_URL")
  // Direct connection — used by Prisma migrate / introspect only.
  directUrl = env("DIRECT_URL")
}

// ══════════════════════════════════════
// MULTI-TENANCY
// ══════════════════════════════════════

model Account {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  plan              Plan     @default(FREE)
  locale            String   @default("pt")
  timezone          String   @default("America/Sao_Paulo")
  stripeCustomerId  String?  @unique @map("stripe_customer_id")
  stripeSubId       String?  @map("stripe_sub_id")
  stripeSubStatus   String?  @map("stripe_sub_status")
  stripePriceId     String?  @map("stripe_price_id")
  trialEndsAt       DateTime? @map("trial_ends_at")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  maxUsers          Int      @default(5) @map("max_users")
  createdById       String?  @map("created_by_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  members           AccountMember[]
  leads             Lead[]
  conversations     Conversation[]
  messages          Message[]
  campaigns         Campaign[]
  aiConfig          AIConfig?
  knowledgeBase     KnowledgeEntry[]
  channels          Channel[]
  webhooks          Webhook[]
  eventLogs         EventLog[]
  googleCalendar    GoogleCalendarIntegration?
  metaIntegration   MetaIntegration?
  createdBy         User?            @relation("AccountCreatedBy", fields: [createdById], references: [id])

  @@index([createdById])
  @@map("accounts")
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

model AccountMember {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  userId    String   @map("user_id")
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@map("account_members")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id           String       @id @default(cuid())
  supabaseId   String       @unique @map("supabase_id")
  email        String       @unique
  name         String?
  avatarUrl    String?      @map("avatar_url")
  platformRole PlatformRole @default(USER) @map("platform_role")
  createdAt    DateTime     @default(now()) @map("created_at")

  memberships     AccountMember[]
  createdAccounts Account[]       @relation("AccountCreatedBy")

  @@map("users")
}

enum PlatformRole {
  USER
  SUPER_ADMIN
  HIPER_ADMIN
}

// ══════════════════════════════════════
// LEADS
// ══════════════════════════════════════

model Lead {
  id            String     @id @default(cuid())
  accountId     String     @map("account_id")
  name          String?
  email         String?
  phone         String?
  countryCode   String?    @map("country_code")
  status        LeadStatus @default(NEW)
  source        LeadSource @default(MARKETING)
  score         Int        @default(0)
  tags          String[]   @default([])
  metadata      Json?
  notes         String?
  campaignId    String?    @map("campaign_id")
  lastContactAt DateTime?  @map("last_contact_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaign      Campaign?     @relation(fields: [campaignId], references: [id])
  conversations Conversation[]

  @@index([accountId, status])
  @@index([accountId, createdAt])
  @@index([phone])
  @@index([email])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_CONVERSATION
  QUALIFIED
  CONVERTED
  LOST
  UNRESPONSIVE
}

enum LeadSource {
  MARKETING
  WEBSITE
  MANUAL
  API
  REFERRAL
}

// ══════════════════════════════════════
// CONVERSATIONS & MESSAGES
// ══════════════════════════════════════

model Conversation {
  id                 String      @id @default(cuid())
  accountId          String      @map("account_id")
  leadId             String      @map("lead_id")
  channel            ChannelType
  channelIdentifier  String?     @map("channel_identifier")
  isActive           Boolean     @default(true) @map("is_active")
  isAIEnabled        Boolean     @default(true) @map("is_ai_enabled")
  sentiment          String?
  lastMessageAt      DateTime?   @map("last_message_at")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([accountId, leadId, channel])
  @@index([accountId, isActive])
  @@map("conversations")
}

enum ChannelType {
  WHATSAPP
  EMAIL
  SMS
}

model Message {
  id             String      @id @default(cuid())
  accountId      String      @map("account_id")
  conversationId String      @map("conversation_id")
  direction      Direction
  content        String
  contentType    ContentType @default(TEXT) @map("content_type")
  isAIGenerated  Boolean     @default(false) @map("is_ai_generated")
  externalId     String?     @map("external_id")
  status         String?     @default("SENT")
  metadata       Json?
  sentiment      String?
  tags           String[]    @default([])
  createdAt      DateTime    @default(now()) @map("created_at")

  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([accountId, createdAt])
  @@map("messages")
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum ContentType {
  TEXT
  AUDIO
  IMAGE
  VIDEO
  DOCUMENT
}

// ══════════════════════════════════════
// CAMPAIGNS
// ══════════════════════════════════════

model Campaign {
  id             String   @id @default(cuid())
  accountId      String   @map("account_id")
  name           String
  description    String?
  type           String   @default("DIGITAL")
  status         String   @default("ACTIVE")
  platform       String?
  mediaUrl       String?  @map("media_url")
  mediaFormat    String?  @map("media_format")
  transcription  String?  @db.Text
  totalLeads     Int      @default(0) @map("total_leads")
  convertedLeads Int      @default(0) @map("converted_leads")
  metadata       Json?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  leads   Lead[]

  @@index([accountId])
  @@map("campaigns")
}

// ══════════════════════════════════════
// AI CONFIGURATION
// ══════════════════════════════════════

model AIConfig {
  id               String   @id @default(cuid())
  accountId        String   @unique @map("account_id")
  provider         String   @default("openai")
  model            String   @default("gpt-4o")
  systemPrompt     String   @map("system_prompt") @db.Text
  temperature      Float    @default(0.7)
  maxTokens        Int      @default(1000) @map("max_tokens")
  persona          Json?
  rules            Json?
  businessHours    Json?    @map("business_hours")
  offHoursMessage  String?  @map("off_hours_message")
  escalationConfig Json?    @map("escalation_config")
  conversionConfig Json?    @map("conversion_config")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

model KnowledgeEntry {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  title     String
  content   String   @db.Text
  category  String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, category])
  @@map("knowledge_entries")
}

// ══════════════════════════════════════
// CHANNEL CONFIGS (per-account)
// ══════════════════════════════════════

model Channel {
  id        String      @id @default(cuid())
  accountId String      @map("account_id")
  type      ChannelType
  isEnabled Boolean     @default(false) @map("is_enabled")
  config    Json
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, type])
  @@map("channels")
}

// ══════════════════════════════════════
// WEBHOOKS
// ══════════════════════════════════════

model Webhook {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  url       String
  secret    String
  events    String[]
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

// ══════════════════════════════════════
// EVENT LOG (audit trail)
// ══════════════════════════════════════

// ══════════════════════════════════════
// GOOGLE CALENDAR (per-account OAuth)
// ══════════════════════════════════════

model MetaIntegration {
  id              String   @id @default(cuid())
  accountId       String   @unique @map("account_id")
  metaUserId      String   @map("meta_user_id")
  metaUserName    String?  @map("meta_user_name")
  email           String?
  accessToken     String   @db.Text @map("access_token")
  tokenExpiresAt  DateTime @map("token_expires_at")
  scope           String   @db.Text
  pages           Json?
  adAccounts      Json?    @map("ad_accounts")
  businessName    String?  @map("business_name")
  businessNiche   String?  @map("business_niche")
  businessProduct String?  @db.Text @map("business_product")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("meta_integrations")
}

model GoogleCalendarIntegration {
  id             String   @id @default(cuid())
  accountId      String   @unique @map("account_id")
  email          String
  calendarId     String   @default("primary") @map("calendar_id")
  accessToken    String   @db.Text @map("access_token")
  refreshToken   String   @db.Text @map("refresh_token")
  tokenExpiresAt DateTime @map("token_expires_at")
  scope          String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("google_calendar_integrations")
}

model EventLog {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  event     String
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, event])
  @@index([accountId, createdAt])
  @@map("event_logs")
}
